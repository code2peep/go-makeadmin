# Gin 运行模式：debug 或 release
GIN_MODE=debug

# API 服务端口
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# API 对外访问地址
PUBLIC_URL=http://127.0.0.1:8000

# MySQL DSN。完整联调前必须先创建数据库并导入初始化 SQL。
DATABASE_URL=root:@tcp(127.0.0.1:3306)/go_makeadmin?charset=utf8mb4&parseTime=True&loc=Local

# Redis URL。无密码本地默认值如下；有密码时使用 redis://:password@127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# 上传文件目录
UPLOAD_DIRECTORY=/tmp/uploads/go-makeadmin/
