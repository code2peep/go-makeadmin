{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "global.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "components.d.ts",
    "auto-imports.d.ts",
    "typings/**/*.d.ts"
  ],
  "compilerOptions": {
    "isolatedModules": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
